# Native development defaults. Docker Compose supplies service-local values for
# the database, API, and artifact paths.
MONO_DATABASE_URL=postgresql+psycopg://mono:mono@localhost:5432/mono
MONO_BASE_URL=http://localhost:8000
# Client-only bearer token. Local dev clients default to rt_mono_dev.
# In normal mode, create a secret token in Access -> Your agent tokens; never commit it.
MONO_API_TOKEN=
MONO_ARTIFACT_PATH=./data/artifacts
MONO_CORS_ORIGINS=http://localhost:3000
MONO_SEED_DEMO=false
MONO_DEV=false
MONO_DEMO=false
MONO_AUTO_MIGRATE=true
MONO_MAX_ARTIFACT_SIZE=10485760
MONO_CLAIM_TIMEOUT_SECONDS=300
MONO_EMBEDDINGS_ENABLED=true
MONO_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
MONO_EMBEDDING_CACHE_PATH=./data/models
MONO_SECURE_SESSION_COOKIE=false
# One-time migration aid for a passkey-era owner. Remove after the first start.
MONO_OWNER_RECOVERY_PASSWORD=
MONO_SESSION_TTL_HOURS=168
MONO_SETUP_LINK_TTL_HOURS=24
